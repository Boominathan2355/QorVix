{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "linux-debug",
      "inherits": ["base", "vcpkg"],
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-release",
      "inherits": ["base", "vcpkg"],
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "windows-debug",
      "inherits": ["base", "vcpkg"],
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "quick",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/quick",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "description": "No vcpkg toolchain — only builds targets with zero third-party deps. For fast local iteration before vcpkg is bootstrapped."
    },
    {
      "name": "quick-release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/quick-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QORVIX_NATIVE": "ON"
      },
      "description": "Optimized, dependency-free build (-O3 + -march=native + OpenMP). For benchmarking the CPU runtime without vcpkg."
    }
  ],
  "buildPresets": [
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    { "name": "linux-release", "configurePreset": "linux-release" },
    { "name": "windows-debug", "configurePreset": "windows-debug" },
    { "name": "quick", "configurePreset": "quick" },
    { "name": "quick-release", "configurePreset": "quick-release" }
  ],
  "testPresets": [
    { "name": "linux-debug", "configurePreset": "linux-debug", "output": { "outputOnFailure": true } },
    { "name": "linux-release", "configurePreset": "linux-release", "output": { "outputOnFailure": true } },
    { "name": "quick", "configurePreset": "quick", "output": { "outputOnFailure": true } }
  ]
}
